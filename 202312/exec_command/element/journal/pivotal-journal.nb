 CellChangeTimes->{{3.9814179538555317`*^9, 3.981417960407522*^9}},
 CellLabel->
  "In[108]:=",ExpressionUUID->"258e08e4-7673-4cde-b6d8-68573305fed8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TallyUnion", "[", "tly__List", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"gath", ",", "key", ",", "val"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"gath", "=", 
      RowBox[{"GatherBy", "[", 
       RowBox[{
        RowBox[{"Join", "[", "tly", "]"}], ",", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "&"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"key", "=", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}], "&"}], ",", "gath"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"val", "=", 
      RowBox[{"Map", "[", 
       RowBox[{"Total", ",", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}], "&"}], ",", "gath", ",", 
          RowBox[{"{", "2", "}"}]}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"key", ",", "val"}], "}"}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9814161439849*^9, 3.981416189974717*^9}, {
