 CellChangeTimes->{{3.9814248892894907`*^9, 3.981424904941184*^9}},
 CellLabel->
  "In[291]:=",ExpressionUUID->"30e08bc6-7710-4e92-bbbe-809e4266eb15"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"KLD", "[", 
    RowBox[{"p_", ",", "q_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"pd", ",", "qd", ",", "pl", ",", "ql"}], "}"}], ",", 
     RowBox[{
      RowBox[{"pd", "=", 
       RowBox[{"p", "/", 
        RowBox[{"Total", "[", "p", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"qd", "=", 
       RowBox[{"q", "/", 
        RowBox[{"Total", "[", "q", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"pl", "=", 
       RowBox[{"Length", "[", "p", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"ql", "=", 
       RowBox[{"Length", "[", "q", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"pl", "!=", "ql"}], ",", 
        RowBox[{"Error", "[", "\"\<no match length.\>\"", "]"}], ",", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"pd", "[", 
              RowBox[{"[", "n", "]"}], "]"}], " ", 
             RowBox[{"logz", "[", 
              RowBox[{
               RowBox[{"pd", "[", 
                RowBox[{"[", "n", "]"}], "]"}], "/", 
               RowBox[{"qd", "[", 
                RowBox[{"[", "n", "]"}], "]"}]}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "pl"}], "}"}]}], "]"}], "]"}], "/.", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "Infinity"}], "->", "0"}], ")"}]}]}], "]"}]}]}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981424334950397*^9, 3.98142434448355*^9}, {
  3.981424469763486*^9, 3.981424472269372*^9}},
 CellLabel->
  "In[292]:=",ExpressionUUID->"30813df6-1b3a-4416-80e5-239a263868a7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"KLDComponents", "[", 
    RowBox[{"p_", ",", "q_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"pd", ",", "qd", ",", "pl", ",", "ql"}], "}"}], ",", 
     RowBox[{
      RowBox[{"pd", "=", 
       RowBox[{"p", "/", 
        RowBox[{"Total", "[", "p", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"qd", "=", 
       RowBox[{"q", "/", 
        RowBox[{"Total", "[", "q", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"pl", "=", 
       RowBox[{"Length", "[", "p", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"ql", "=", 
       RowBox[{"Length", "[", "q", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"pl", "!=", "ql"}], ",", 
        RowBox[{"Error", "[", "\"\<no match length.\>\"", "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"pd", "[", 
            RowBox[{"[", "n", "]"}], "]"}], " ", 
           RowBox[{"logz", "[", 
            RowBox[{
             RowBox[{"pd", "[", 
              RowBox[{"[", "n", "]"}], "]"}], "/", 
             RowBox[{"qd", "[", 
              RowBox[{"[", "n", "]"}], "]"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "pl"}], "}"}]}], "]"}]}], "]"}]}]}], " ", 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981424334950397*^9, 3.98142434448355*^9}, {
  3.981424469763486*^9, 3.981424472269372*^9}, {3.981424799825543*^9, 
