Cell[BoxData[
 RowBox[{
  RowBox[{"logz", "[", "n_", "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"n", "==", "0"}], ",", "0", ",", 
    RowBox[{"Log", "[", "n", "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.98142440130464*^9, 3.9814244639861507`*^9}},
